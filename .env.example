# ---------------------------------------------------------------------------
# Everything below is OPTIONAL. With no .env at all, the app runs on a local
# JSON file store and most settings can be edited in the admin panel instead.
# Admin -> Settings is the source of truth; these env vars only seed defaults.
# ---------------------------------------------------------------------------

# Postgres. If the connection fails (e.g. wrong password) the app automatically
# falls back to the local file store, so a bad value never breaks the site.
# To use Postgres: create the DB/role, set this URL, then open
# Admin -> Settings -> Data storage -> "Create / update tables".
DATABASE_URL="postgres://postgres:postgres@localhost:5432/private_nail_studio"
PGSSL="false"

# Admin login. First run seeds an admin from these (or the owner email below).
# Default password is "admin1234" until you set ADMIN_PASSWORD or change it in Settings.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
# Secret used to sign login sessions. If unset, a random one is generated and
# stored in .data/auth-secret (set this in production for stable sessions).
AUTH_SECRET=""

# Studio identity (editable later in Admin -> Settings)
STUDIO_NAME="Nunez Nails"
STUDIO_OWNER_NAME="Gisela"
STUDIO_EMAIL="hello@nuneznails.com"
STUDIO_OWNER_EMAIL="hello@nuneznails.com"
STUDIO_PHONE="(555) 123-4567"
STUDIO_LOCATION_NAME="Nunez Nails Private Studio"
STUDIO_ADDRESS="123 Beauty Lane, Houston, TX 77001"
STUDIO_TIMEZONE="America/Chicago"

# Email. Configure ONE provider (also editable in Admin -> Settings -> Email).
# Precedence: Mailtrap > Resend > SMTP > local outbox.
EMAIL_FROM="Nunez Nails <hello@nuneznails.com>"

# Mailtrap. Leave MAILTRAP_INBOX_ID set to capture emails in a testing inbox
# (not delivered to clients); clear it to send for real (needs a verified/demo domain).
MAILTRAP_API_TOKEN=""
MAILTRAP_INBOX_ID=""
MAILTRAP_FROM="Nunez Nails <hello@nuneznails.com>"

# Resend (needs a verified domain at resend.com/domains).
RESEND_API_KEY=""
RESEND_FROM="Nunez Nails <hello@nuneznails.com>"

# Gmail / SMTP. For Gmail, create an App Password and paste it as SMTP_PASS.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# Payments / deposits (Stripe). Leave empty to keep booking free.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_DEPOSIT_CENTS="2000"

# Google. Places key powers live reviews; Maps Static key renders email maps.
GOOGLE_PLACES_API_KEY=""
GOOGLE_MAPS_STATIC_API_KEY=""

# SMS / WhatsApp (Twilio). Leave empty to use email only.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
TWILIO_WHATSAPP_FROM=""

# Social embeds (existing)
INSTAGRAM_USER_ID=""
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_GRAPH_VERSION="v23.0"
PINTEREST_ACCESS_TOKEN=""
PINTEREST_BOARD_ID=""
PINTEREST_BOARD_NAME="Nail Inspo"
PINTEREST_PROFILE_NAME="Nunez Nails"
PINTEREST_PROFILE_URL=""
